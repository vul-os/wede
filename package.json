    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
